{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resume Interview Workbench",
  "version": "0.1.0",
  "identifier": "com.zgx197.resume-interview-workbench",
  "build": {
    "beforeDevCommand": "npm run dev:no-open",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../app/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Resume Interview Workbench",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
